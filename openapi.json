                                    "items": {
                                        "$ref": "#/components/schemas/HoldingResponse"
                                    },
                                    "type": "array",
                                    "title": "Response List Holdings Holdings Get"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "holdings"
                ],
                "summary": "Add Holding",
                "operationId": "add_holding_holdings_post",
