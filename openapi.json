                        "title": "Prev Close"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "exchange": {
                        "type": "string",
                        "title": "Exchange"
                    },
                    "currency": {
                        "type": "string",
                        "title": "Currency"
