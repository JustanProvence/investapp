                    "ticker": {
                        "type": "string",
                        "title": "Ticker"
                    },
                    "shares": {
                        "type": "number",
                        "title": "Shares"
                    },
                    "cost_basis": {
                        "type": "number",
                        "title": "Cost Basis"
                    }
                },
                "type": "object",
                "required": [
                    "ticker",
                    "shares",
                    "cost_basis"
                ],
                "title": "HoldingCreate"
            },
            "HoldingResponse": {
                "properties": {
                    "ticker": {
                        "type": "string",
                        "title": "Ticker"
                    },
                    "shares": {
                        "type": "number",
                        "title": "Shares"
                    },
                    "cost_basis": {
                        "type": "number",
                        "title": "Cost Basis"
                    }
                },
                "type": "object",
                "required": [
                    "ticker",
                    "shares",
                    "cost_basis"
