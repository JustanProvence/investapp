                        "title": "Total Value"
                    },
                    "portfolio_yield": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Portfolio Yield"
                    },
                    "total_invested": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
