                "properties": {
                    "ticker": {
                        "type": "string",
                        "title": "Ticker"
                    },
                    "price": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Price"
                    },
                    "change": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Change"
                    },
                    "change_pct": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Change Pct"
                    },
                    "prev_close": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
