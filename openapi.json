                        "title": "Total Invested"
                    },
                    "unrealized_gain": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Unrealized Gain"
                    },
                    "unrealized_pct": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
