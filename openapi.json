                    "value": {
                        "type": "string",
                        "title": "Value"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "good",
                            "warn",
                            "bad"
                        ],
                        "title": "Status"
                    },
                    "description": {
                        "type": "string",
                        "title": "Description"
                    }
                },
                "type": "object",
                "required": [
                    "name",
                    "value",
                    "status",
                    "description"
